<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %> – EventPro
    </title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎫</text></svg>" />
</head>

<body>
    <%- include('../partials/navbar') %>

        <div class="container">
            <div class="dashboard-layout">
                <%- include('_sidebar') %>

                    <div>
                        <div class="flex-between mb-4">
                            <h1 style="font-size:1.6rem;">My Profile</h1>
                        </div>

                        <% if (error) { %>
                            <div class="alert alert-error">⚠️ <%= error %>
                            </div>
                            <% } %>
                                <% if (success) { %>
                                    <div class="alert alert-success">✅ <%= success %>
                                    </div>
                                    <% } %>

                                        <div class="card" style="padding:2rem;max-width:600px;">
                                            <form action="/dashboard/profile" method="POST"
                                                enctype="multipart/form-data">

                                                <!-- Avatar preview -->
                                                <div
                                                    style="display:flex;align-items:center;gap:1.5rem;margin-bottom:2rem;">
                                                    <div
                                                        style="width:80px;height:80px;border-radius:var(--radius-md);background:var(--primary-light);border:2px solid var(--primary-dim);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:var(--primary);overflow:hidden;flex-shrink:0;">
                                                        <% if (profile.avatar) { %>
                                                            <img src="<%= profile.avatar %>"
                                                                style="width:100%;height:100%;object-fit:cover;" />
                                                            <% } else { %>
                                                                <%= profile.full_name.charAt(0).toUpperCase() %>
                                                                    <% } %>
                                                    </div>
                                                    <div>
                                                        <p class="text-sm text-muted mb-1">Profile Photo</p>
                                                        <input type="file" name="avatar" class="form-control"
                                                            accept="image/*" style="padding:0.4rem;" />
                                                    </div>
                                                </div>

                                                <div class="form-group">
                                                    <label class="form-label">Full Name</label>
                                                    <input type="text" name="full_name" class="form-control"
                                                        value="<%= profile.full_name %>" required />
                                                </div>

                                                <div class="form-group">
                                                    <label class="form-label">Email</label>
                                                    <input type="email" class="form-control"
                                                        value="<%= profile.email %>" disabled
                                                        style="opacity:0.5;cursor:not-allowed;" />
                                                    <p class="text-sm text-muted mt-1">Email cannot be changed.</p>
                                                </div>

                                                <div class="form-group">
                                                    <label class="form-label">Bio</label>
                                                    <textarea name="bio" class="form-control"
                                                        placeholder="Tell us a bit about yourself..."><%= profile.bio || '' %></textarea>
                                                </div>

                                                <div
                                                    style="background:var(--bg-subtle);border:1px solid var(--border);border-radius:var(--radius-md);padding:0.9rem 1rem;margin-bottom:1.2rem;">
                                                    <p class="text-sm text-muted">Role: <span
                                                            class="role-badge role-badge--<%= profile.role %>"
                                                            style="margin-left:0.3rem;">
                                                            <%= profile.role %>
                                                        </span></p>
                                                    <p class="text-sm text-muted mt-1">Member since: <%= new
                                                            Date(profile.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'})
                                                            %>
                                                    </p>
                                                </div>

                                                <button type="submit" class="btn btn-primary">Update Profile</button>
                                            </form>
                                        </div>
                    </div>
            </div>
        </div>

        <%- include('../partials/footer') %>
            <script src="/js/main.js"></script>
</body>

</html>