<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reports – EventPro</title>
    <link rel="stylesheet" href="/css/main.css" />
</head>

<body>
    <%- include('../partials/navbar') %>
        <div class="container" style="padding:2rem 1.5rem;">
            <div class="flex-between mb-4">
                <h1 style="font-size:1.6rem;">📊 Reports</h1>
                <a href="/admin/dashboard" class="btn btn-ghost btn-sm">← Dashboard</a>
            </div>

            <div class="stat-grid mb-4">
                <div class="stat-card">
                    <span class="stat-card__icon">🎫</span>
                    <span class="stat-card__value text-gradient">
                        <%= totalBookings %>
                    </span>
                    <span class="stat-card__label">Total Confirmed Bookings</span>
                </div>
                <div class="stat-card">
                    <span class="stat-card__icon">💰</span>
                    <span class="stat-card__value" style="color:var(--green);">₹<%=
                            parseFloat(revenue).toLocaleString('en-IN') %></span>
                    <span class="stat-card__label">Total Revenue</span>
                </div>
            </div>

            <div class="section-title mb-2">All Bookings</div>
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>User</th>
                            <th>Event</th>
                            <th>Qty</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentBookings.forEach(b=> { %>
                            <tr>
                                <td class="text-muted text-sm">#<%= b.id %>
                                </td>
                                <td>
                                    <strong>
                                        <%= b.full_name %>
                                    </strong><br />
                                    <span class="text-sm text-muted">
                                        <%= b.email %>
                                    </span>
                                </td>
                                <td class="text-sm">
                                    <%= b.event_title %>
                                </td>
                                <td class="text-sm">
                                    <%= b.quantity %>
                                </td>
                                <td class="text-sm text-green">₹<%= parseFloat(b.total_amount).toLocaleString('en-IN')
                                        %>
                                </td>
                                <td>
                                    <span
                                        class="badge <%= b.status==='confirmed'?'badge-green':b.status==='cancelled'?'badge-rose':'badge-grey' %>">
                                        <%= b.status %>
                                    </span>
                                </td>
                                <td class="text-sm text-muted">
                                    <%= new Date(b.booked_at).toLocaleDateString('en-IN') %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <%- include('../partials/footer') %>
</body>

</html>