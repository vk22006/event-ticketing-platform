<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %> – EventPro
    </title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎫</text></svg>" />
</head>

<body>
    <%- include('../partials/navbar') %>

        <div class="container">
            <div class="dashboard-layout">

                <!-- Sidebar -->
                <%- include('_sidebar') %>

                    <!-- Main content -->
                    <div>
                        <div class="flex-between mb-4">
                            <div>
                                <h1 style="font-size:1.6rem;">Dashboard</h1>
                                <p class="text-muted text-sm">Welcome back, <%= user.full_name %> 👋</p>
                            </div>
                            <% if (user.role==='organizer' ) { %>
                                <a href="/events/create" class="btn btn-primary">+ Create Event</a>
                                <% } else { %>
                                    <a href="/events" class="btn btn-primary">Browse Events 🎫</a>
                                    <% } %>
                        </div>

                        <% if (user.role==='organizer' ) { %>
                            <!-- ORGANIZER VIEW -->
                            <% if (events && events.length===0) { %>
                                <div class="empty-state">
                                    <div class="empty-state__icon">🎉</div>
                                    <h3>No events yet</h3>
                                    <p>Create your first event to get started</p>
                                    <a href="/events/create" class="btn btn-primary mt-3">Create Event</a>
                                </div>
                                <% } else if (events) { %>
                                    <div class="table-wrapper">
                                        <table class="table">
                                            <thead>
                                                <tr>
                                                    <th>Event</th>
                                                    <th>Date</th>
                                                    <th>Seats</th>
                                                    <th>Price</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% events.forEach(evt=> { %>
                                                    <tr>
                                                        <td>
                                                            <strong>
                                                                <%= evt.title %>
                                                            </strong><br />
                                                            <span class="text-muted text-sm">📍 <%= evt.city %></span>
                                                        </td>
                                                        <td class="text-sm">
                                                            <%= new Date(evt.event_date).toLocaleDateString('en-IN') %>
                                                        </td>
                                                        <td class="text-sm">
                                                            <%= evt.available_seats %> / <%= evt.total_seats %>
                                                        </td>
                                                        <td class="text-sm">
                                                            <% if (evt.ticket_price==0) { %>
                                                                <span class="badge badge-green">Free</span>
                                                                <% } else { %>
                                                                    ₹<%= parseFloat(evt.ticket_price).toLocaleString('en-IN')
                                                                        %>
                                                                        <% } %>
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="badge <%= evt.status === 'published' ? 'badge-green' : evt.status === 'cancelled' ? 'badge-rose' : 'badge-grey' %>">
                                                                <%= evt.status %>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
                                                                <a href="/events/<%= evt.id %>/edit"
                                                                    class="btn btn-ghost btn-sm">Edit</a>
                                                                <form action="/events/<%= evt.id %>/toggle-status"
                                                                    method="POST" style="display:inline">
                                                                    <button
                                                                        class="btn btn-sm <%= evt.status === 'published' ? 'btn-danger' : 'btn-success' %>">
                                                                        <%= evt.status==='published' ? 'Unpublish'
                                                                            : 'Publish' %>
                                                                    </button>
                                                                </form>
                                                                <form action="/events/<%= evt.id %>/delete"
                                                                    method="POST" style="display:inline"
                                                                    onsubmit="return confirm('Delete this event?')">
                                                                    <button
                                                                        class="btn btn-danger btn-sm">Delete</button>
                                                                </form>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                    <% } %>

                                        <% } else { %>
                                            <!-- USER VIEW -->
                                            <% if (bookings && bookings.length===0) { %>
                                                <div class="empty-state">
                                                    <div class="empty-state__icon">🎟️</div>
                                                    <h3>No bookings yet</h3>
                                                    <p>Discover and book your first event!</p>
                                                    <a href="/events" class="btn btn-primary mt-3">Browse Events</a>
                                                </div>
                                                <% } else if (bookings) { %>
                                                    <div class="events-grid"
                                                        style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr));">
                                                        <% bookings.forEach(b=> { %>
                                                            <div class="card">
                                                                <div class="card__image" style="height:120px;">
                                                                    <% if (b.banner_image) { %>
                                                                        <img src="<%= b.banner_image %>"
                                                                            style="width:100%;height:120px;object-fit:cover;" />
                                                                        <% } else { %>
                                                                            🎫
                                                                            <% } %>
                                                                </div>
                                                                <div class="card__body">
                                                                    <h3 class="card__title" style="font-size:0.95rem;">
                                                                        <%= b.event_title %>
                                                                    </h3>
                                                                    <p class="text-sm text-muted">📅 <%= new
                                                                            Date(b.event_date).toLocaleDateString('en-IN')
                                                                            %>
                                                                    </p>
                                                                    <p class="text-sm text-muted">📍 <%= b.venue || ''
                                                                            %>
                                                                            <%= b.city %>
                                                                    </p>
                                                                    <div class="flex gap-1 mt-2"
                                                                        style="flex-wrap:wrap;">
                                                                        <span
                                                                            class="badge <%= b.status==='confirmed'?'badge-green':b.status==='cancelled'?'badge-rose':'badge-grey' %>">
                                                                            <%= b.status %>
                                                                        </span>
                                                                        <span class="badge badge-purple">₹<%=
                                                                                parseFloat(b.total_amount).toLocaleString('en-IN')
                                                                                %></span>
                                                                    </div>
                                                                </div>
                                                                <div class="card__footer">
                                                                    <a href="/tickets/my"
                                                                        class="btn btn-ghost btn-sm">View Ticket</a>
                                                                    <% if (b.status==='confirmed' ) { %>
                                                                        <form action="/bookings/<%= b.id %>/cancel"
                                                                            method="POST"
                                                                            onsubmit="return confirm('Cancel this booking?')">
                                                                            <button
                                                                                class="btn btn-danger btn-sm">Cancel</button>
                                                                        </form>
                                                                        <% } %>
                                                                </div>
                                                            </div>
                                                            <% }) %>
                                                    </div>
                                                    <% } %>
                                                        <% } %>
                    </div>

            </div>
        </div>

        <%- include('../partials/footer') %>
            <script src="/js/main.js"></script>
</body>

</html>