<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account – EventPro</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎫</text></svg>" />
</head>

<body>
    <%- include('../partials/navbar') %>

        <div class="flex-center" style="min-height:calc(100vh - 140px);padding:2rem 1rem;">
            <div class="card container-sm" style="max-width:480px;width:100%;padding:2.5rem;">

                <div class="text-center mb-3">
                    <div style="font-size:3rem;margin-bottom:0.5rem;">🎫</div>
                    <h1 style="font-size:1.75rem;">Create Account</h1>
                    <p class="text-muted text-sm">Join EventPro and start your journey</p>
                </div>

                <% if (error) { %>
                    <div class="alert alert-error">⚠️ <%= error %>
                    </div>
                    <% } %>

                        <form action="/auth/register" method="POST" id="registerForm">
                            <div class="form-group">
                                <label class="form-label">Full Name</label>
                                <input type="text" name="full_name" class="form-control" placeholder="John Doe"
                                    required />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control" placeholder="john@example.com"
                                    required />
                            </div>
                            <div class="form-group">
                                <label class="form-label">I want to</label>
                                <select name="role" class="form-control">
                                    <option value="user">Attend Events (User)</option>
                                    <option value="organizer">Organise Events (Organizer)</option>
                                </select>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Password</label>
                                    <input type="password" name="password" id="password" class="form-control"
                                        placeholder="Min 6 characters" required />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Confirm Password</label>
                                    <input type="password" name="confirm_password" class="form-control"
                                        placeholder="Repeat password" required />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-block btn-lg">Create Account</button>
                        </form>

                        <div class="divider mt-3">already have an account?</div>
                        <a href="/auth/login" class="btn btn-ghost btn-block">Sign In</a>
            </div>
        </div>

        <%- include('../partials/footer') %>
</body>

</html>