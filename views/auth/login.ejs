<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In – EventPro</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎫</text></svg>" />
</head>

<body>
    <%- include('../partials/navbar') %>

        <div class="flex-center" style="min-height:calc(100vh - 140px);padding:2rem 1rem;">
            <div class="card" style="max-width:440px;width:100%;padding:2.5rem;">

                <div class="text-center mb-3">
                    <div style="font-size:3rem;margin-bottom:0.5rem;">👋</div>
                    <h1 style="font-size:1.75rem;">Welcome Back</h1>
                    <p class="text-muted text-sm">Sign in to your EventPro account</p>
                </div>

                <% if (error) { %>
                    <div class="alert alert-error">⚠️ <%= error %>
                    </div>
                    <% } %>

                        <form action="/auth/login" method="POST">
                            <div class="form-group">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control" placeholder="john@example.com"
                                    required autofocus />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" placeholder="Your password"
                                    required />
                            </div>
                            <button type="submit" class="btn btn-primary btn-block btn-lg">Sign In</button>
                        </form>

                        <div class="divider mt-3">test credentials</div>
                        <div
                            style="background:rgba(124,92,252,0.08);border:1px solid rgba(124,92,252,0.2);border-radius:var(--radius-md);padding:0.9rem 1rem;font-size:0.8rem;color:var(--text-secondary);">
                            <p>🛡️ <strong>Admin:</strong> admin@eventpro.com / Admin@1234</p>
                            <p>🎪 <strong>Organizer:</strong> alice@events.com / Organizer@1</p>
                            <p>🙋 <strong>User:</strong> charlie@mail.com / User@1234</p>
                        </div>

                        <div class="divider">new here?</div>
                        <a href="/auth/register" class="btn btn-ghost btn-block">Create Account</a>
            </div>
        </div>

        <%- include('../partials/footer') %>
</body>

</html>